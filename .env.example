# NetVantage Environment Configuration
# Copy to .env and fill in production values.

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Grafana Admin ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Grafana OAuth2/OIDC SSO ---
# Uncomment and configure for SSO integration.
# GF_AUTH_OIDC_ENABLED=true
# GF_AUTH_OIDC_NAME=Okta
# GF_AUTH_OIDC_CLIENT_ID=your-client-id
# GF_AUTH_OIDC_CLIENT_SECRET=your-client-secret
# GF_AUTH_OIDC_AUTH_URL=https://your-idp.example.com/authorize
# GF_AUTH_OIDC_TOKEN_URL=https://your-idp.example.com/token
# GF_AUTH_OIDC_API_URL=https://your-idp.example.com/userinfo
# GF_AUTH_OIDC_SCOPES=openid profile email
# GF_COOKIE_SECURE=true

# --- NetVantage Server ---
# NETVANTAGE_DB_URL=postgres://netvantage:CHANGE_ME@postgres:5432/netvantage?sslmode=require
# NETVANTAGE_JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_SECRET
# NETVANTAGE_TLS_ENABLED=true
# NETVANTAGE_TLS_CERT=/certs/server.crt
# NETVANTAGE_TLS_KEY=/certs/server.key

# --- Kafka (when using Kafka transport) ---
# NETVANTAGE_TRANSPORT=kafka
# NETVANTAGE_KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
# NETVANTAGE_KAFKA_SASL_ENABLED=true
# NETVANTAGE_KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# NETVANTAGE_KAFKA_SASL_USERNAME=netvantage
# NETVANTAGE_KAFKA_SASL_PASSWORD=CHANGE_ME
# NETVANTAGE_KAFKA_TLS_ENABLED=true
