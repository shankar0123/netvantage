# Dockerfile.agent — NetVantage Canary Agent
#
# Multi-stage build: compile Go binary, copy into minimal runtime image.
# Supports multi-arch: linux/amd64, linux/arm64.
#
# Note: The agent needs CAP_NET_RAW for ICMP ping and traceroute.
# Run with: docker run --cap-add=NET_RAW netvantage-agent

FROM golang:1.22-alpine AS builder

WORKDIR /src

# Cache dependencies.
COPY go.mod go.sum ./
RUN go mod download

# Build the agent binary.
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bin/netvantage-agent ./cmd/agent/

# --- Runtime ---
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata mtr

COPY --from=builder /bin/netvantage-agent /usr/local/bin/netvantage-agent

ENTRYPOINT ["netvantage-agent"]
