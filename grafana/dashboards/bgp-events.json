  "description": "BGP Event Timeline — hijack detection, RPKI validation, ROA expiry monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Home",
      "type": "link",
      "url": "/d/netvantage-home/netvantage-home"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total BGP Events (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(netvantage_bgp_event_total[1h]))",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Hijacks Detected (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(netvantage_bgp_hijack_total[1h]))",
          "legendFormat": "Hijacks"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "RPKI Invalid (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(netvantage_bgp_event_total{event_type=\"rpki_invalid\"}[1h]))",
          "legendFormat": "RPKI Invalid"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Withdrawals (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(netvantage_bgp_event_total{event_type=\"withdrawal\"}[1h]))",
          "legendFormat": "Withdrawals"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisLabel": "Events/min", "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "BGP Event Timeline",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (event_type) (rate(netvantage_bgp_event_total[1m]))",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "drawStyle": "bars", "fillOpacity": 90, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Hijacks by Type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (hijack_type) (rate(netvantage_bgp_hijack_total[5m]))",
          "legendFormat": "{{hijack_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "drawStyle": "bars", "fillOpacity": 90, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Events by Prefix",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (prefix) (rate(netvantage_bgp_event_total[5m]))",
          "legendFormat": "{{prefix}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 7 }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 }] },
          "unit": "d"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "area", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "ROA Expiry Countdown",
      "type": "stat",
      "targets": [
        {
          "expr": "netvantage_bgp_roa_expiry_days",
          "legendFormat": "{{prefix}} (AS{{asn}})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [
            { "options": { "valid": { "color": "green", "index": 0, "text": "VALID" } }, "type": "value" },
            { "options": { "invalid": { "color": "red", "index": 1, "text": "INVALID" } }, "type": "value" },
            { "options": { "not-found": { "color": "yellow", "index": 2, "text": "NOT FOUND" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "status" }] },
      "title": "RPKI Status by Prefix",
      "type": "table",
      "targets": [
        {
          "expr": "netvantage_bgp_rpki_status == 1",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "origin_asn": "Origin AS", "prefix": "Prefix", "status": "RPKI Status", "Value": "" } } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 300 }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 28 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Analyzer Staleness (seconds since last update)",
      "type": "stat",
      "targets": [
        {
          "expr": "time() - netvantage_bgp_analyzer_last_update",
          "legendFormat": "{{collector}}"
        }
      ]
    },
    {
      "title": "--- BGP + Traceroute Correlation (M8) ---",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "title": "Path Correlation Status",
      "description": "Current correlation status per prefix/POP. 1=exact match, 0.5=partial (transit diverges), 0=mismatch (origin differs), -1=insufficient data",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "1": { "text": "MATCH", "color": "green" }, "0.5": { "text": "PARTIAL", "color": "yellow" }, "0": { "text": "MISMATCH", "color": "red" }, "-1": { "text": "NO DATA", "color": "blue" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "targets": [
        { "expr": "netvantage_path_correlation_status{prefix=~\"$prefix\"}", "legendFormat": "{{ prefix }} → {{ target }} @ {{ pop }}" }
      ]
    },
    {
      "title": "Path Mismatches Over Time",
      "description": "Timeline of BGP vs. traceroute path mismatches — spikes indicate routing anomalies",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 80 }, "color": { "mode": "palette-classic" } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "increase(netvantage_path_correlation_mismatch_total{prefix=~\"$prefix\"}[5m])", "legendFormat": "{{ match_type }}: {{ prefix }} @ {{ pop }}" }
      ]
    },
    {
      "title": "BGP vs. Traceroute Path Comparison",
      "description": "Side-by-side view of BGP-announced and traceroute-observed AS paths. Compare the paths to identify discrepancies, route leaks, and traffic engineering.",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        { "expr": "netvantage_path_correlation_status{prefix=~\"$prefix\"}", "legendFormat": "", "format": "table", "instant": true },
        { "expr": "netvantage_path_correlation_evaluations_total{prefix=~\"$prefix\"}", "legendFormat": "", "format": "table", "instant": true }
      ]
    },
    {
      "title": "Correlation Evaluations Rate",
      "description": "Rate of correlation evaluations — shows how actively the engine is comparing paths",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(netvantage_path_correlation_evaluations_total{prefix=~\"$prefix\"}[5m])", "legendFormat": "{{ prefix }} @ {{ pop }}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["netvantage", "bgp", "correlation"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(netvantage_bgp_event_total, prefix)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "prefix",
        "query": { "query": "label_values(netvantage_bgp_event_total, prefix)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(netvantage_bgp_event_total, event_type)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "event_type",
        "query": { "query": "label_values(netvantage_bgp_event_total, event_type)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
