{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Avg Ping RTT by POP",
      "description": "Average round-trip time across all targets, per POP. Green <50ms, yellow <200ms, red >=200ms.",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizHeight": 75
      },
      "targets": [
        {
          "expr": "avg by (pop) (netvantage_ping_rtt_seconds{stat=\"avg\", target=\"$target\", pop=~\"$pop\"})",
          "legendFormat": "{{ pop }}"
        }
      ]
    },
    {
      "title": "Avg HTTP TTFB by POP",
      "description": "Time to first byte for HTTP requests, per POP. Green <500ms, yellow <2s, red >=2s.",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizHeight": 75
      },
      "targets": [
        {
          "expr": "avg by (pop) (netvantage_http_duration_seconds{phase=\"ttfb\", target=\"$target\", pop=~\"$pop\"})",
          "legendFormat": "{{ pop }}"
        }
      ]
    },
    {
      "title": "Packet Loss by POP",
      "description": "Average packet loss ratio per POP. Green 0%, yellow >1%, red >5%.",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizHeight": 75
      },
      "targets": [
        {
          "expr": "avg by (pop) (netvantage_ping_packet_loss_ratio{target=\"$target\", pop=~\"$pop\"})",
          "legendFormat": "{{ pop }}"
        }
      ]
    },
    {
      "title": "Comprehensive POP Comparison",
      "description": "Side-by-side metrics across all monitored POPs for the selected target.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #rtt" },
            "properties": [
              { "id": "displayName", "value": "Ping RTT" },
              { "id": "unit", "value": "s" },
              { "id": "custom.align", "value": "auto" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #loss" },
            "properties": [
              { "id": "displayName", "value": "Packet Loss" },
              { "id": "unit", "value": "percentunit" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #ttfb" },
            "properties": [
              { "id": "displayName", "value": "HTTP TTFB" },
              { "id": "unit", "value": "s" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #httptotal" },
            "properties": [
              { "id": "displayName", "value": "HTTP Total" },
              { "id": "unit", "value": "s" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #dns" },
            "properties": [
              { "id": "displayName", "value": "DNS Resolution" },
              { "id": "unit", "value": "s" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #hops" },
            "properties": [
              { "id": "displayName", "value": "Hop Count" },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #mismatch" },
            "properties": [
              { "id": "displayName", "value": "Path Mismatches" },
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Ping RTT", "desc": false }]
      },
      "targets": [
        {
          "expr": "avg by (pop) (netvantage_ping_rtt_seconds{stat=\"avg\", target=\"$target\", pop=~\"$pop\"})",
          "format": "table",
          "instant": true,
          "refId": "rtt"
        },
        {
          "expr": "avg by (pop) (netvantage_ping_packet_loss_ratio{target=\"$target\", pop=~\"$pop\"})",
          "format": "table",
          "instant": true,
          "refId": "loss"
        },
        {
          "expr": "avg by (pop) (netvantage_http_duration_seconds{phase=\"ttfb\", target=\"$target\", pop=~\"$pop\"})",
          "format": "table",
          "instant": true,
          "refId": "ttfb"
        },
        {
          "expr": "avg by (pop) (netvantage_http_duration_seconds{phase=\"total\", target=\"$target\", pop=~\"$pop\"})",
          "format": "table",
          "instant": true,
          "refId": "httptotal"
        },
        {
          "expr": "avg by (pop) (netvantage_dns_resolution_seconds{target=\"$target\", pop=~\"$pop\"})",
          "format": "table",
          "instant": true,
          "refId": "dns"
        },
        {
          "expr": "avg by (pop) (netvantage_traceroute_hop_count{target=\"$target\", pop=~\"$pop\"})",
          "format": "table",
          "instant": true,
          "refId": "hops"
        },
        {
          "expr": "sum by (pop) (netvantage_path_correlation_mismatch_total{target=\"$target\", pop=~\"$pop\"}) or on() vector(0)",
          "format": "table",
          "instant": true,
          "refId": "mismatch"
        }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "pop": "POP" }
          }
        }
      ]
    },
    {
      "title": "Ping RTT Trends by POP",
