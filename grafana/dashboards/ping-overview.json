{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "ICMP Ping monitoring — RTT, packet loss, jitter across all POPs and targets. DASH-02.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Average RTT by Target",
      "description": "Average round-trip time per target across all POPs. The primary health signal — spikes indicate degraded connectivity.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false
          }
        }
      },
      "targets": [
        {
          "expr": "netvantage_ping_rtt_seconds{stat=\"avg\", target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "{{ target }} ({{ pop }})"
        }
      ]
    },
    {
      "title": "Packet Loss by Target",
      "description": "Packet loss ratio per target. Any sustained loss above 0% warrants investigation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "auto"
          },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "netvantage_ping_packet_loss_ratio{target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "{{ target }} ({{ pop }})"
        }
      ]
    },
    {
      "title": "RTT Heatmap",
      "description": "Distribution of average RTT values across all targets and POPs. Darker = more samples at that latency.",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "calculate": true,
        "yAxis": { "unit": "s" },
        "color": {
          "scheme": "Oranges",
          "fill": "dark-orange"
        },
        "cellGap": 1,
        "tooltip": { "show": true }
      },
      "targets": [
        {
          "expr": "netvantage_ping_rtt_seconds{stat=\"avg\", target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "{{ target }} ({{ pop }})"
        }
      ]
    },
    {
      "title": "Jitter Trends",
      "description": "Inter-packet delay variation (mean absolute deviation of consecutive RTTs). High jitter = unstable path, even if average RTT looks fine.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "netvantage_ping_jitter_seconds{target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "{{ target }} ({{ pop }})"
        }
      ]
    },
    {
      "title": "RTT Min / Avg / Max",
      "description": "RTT range per target — the spread between min and max reveals path instability that average alone hides.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5
          }
        }
      },
      "targets": [
        {
          "expr": "netvantage_ping_rtt_seconds{stat=\"min\", target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "min: {{ target }} ({{ pop }})"
        },
        {
          "expr": "netvantage_ping_rtt_seconds{stat=\"avg\", target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "avg: {{ target }} ({{ pop }})"
        },
        {
          "expr": "netvantage_ping_rtt_seconds{stat=\"max\", target=~\"$target\", pop=~\"$pop\"}",
          "legendFormat": "max: {{ target }} ({{ pop }})"
        }
      ]
    },
    {
      "title": "Current Status",
      "description": "At-a-glance status table for all monitored targets — latest RTT, packet loss, and jitter values.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #rtt" },
            "properties": [
              { "id": "displayName", "value": "Avg RTT" },
              { "id": "unit", "value": "s" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #loss" },
            "properties": [
              { "id": "displayName", "value": "Packet Loss" },
              { "id": "unit", "value": "percentunit" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #jitter" },
            "properties": [
              { "id": "displayName", "value": "Jitter" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Avg RTT", "desc": true }]
      },
      "targets": [
        {
          "expr": "netvantage_ping_rtt_seconds{stat=\"avg\", target=~\"$target\", pop=~\"$pop\"}",
          "format": "table",
          "instant": true,
          "refId": "rtt"
        },
        {
          "expr": "netvantage_ping_packet_loss_ratio{target=~\"$target\", pop=~\"$pop\"}",
          "format": "table",
          "instant": true,
          "refId": "loss"
        },
        {
          "expr": "netvantage_ping_jitter_seconds{target=~\"$target\", pop=~\"$pop\"}",
          "format": "table",
          "instant": true,
          "refId": "jitter"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "agent_id": true, "__name__": true, "stat": true, "job": true, "instance": true },
            "renameByName": { "target": "Target", "pop": "POP" }
          }
        }
      ]
    },
    {
      "title": "Results Processed",
      "description": "Rate of ping results flowing through the Metrics Processor. Drops here mean the pipeline is broken.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          }
        }
      },
      "targets": [
        {
          "expr": "rate(netvantage_processor_results_total{test_type=\"ping\"}[5m])",
          "legendFormat": "{{ pop }}"
        }
      ]
    },
    {
      "title": "Processing Errors",
      "description": "Errors in the Metrics Processor — malformed messages, deserialization failures. Should be zero in normal operation.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "increase(netvantage_processor_errors_total{test_type=\"ping\"}[1h])",
          "legendFormat": "{{ error_type }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["netvantage", "ping", "synthetic-monitoring"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      },
      {
        "name": "target",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(netvantage_ping_rtt_seconds, target)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "pop",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(netvantage_ping_rtt_seconds, pop)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NetVantage — Ping Overview",
  "uid": "netvantage-ping-overview",
  "version": 1
}
